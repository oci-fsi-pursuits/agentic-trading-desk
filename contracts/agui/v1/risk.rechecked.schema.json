{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/agui/v1/risk.rechecked.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/baseEnvelope"},
    {
      "properties": {
        "event_type": {"const": "risk.rechecked"},
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["decision_id", "status"],
          "properties": {
            "decision_id": {"type": "string"},
            "status": {"type": "string", "enum": ["passed", "adjusted", "blocked"]}
          }
        }
      }
    }
  ]
}
