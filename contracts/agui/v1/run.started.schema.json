{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/agui/v1/run.started.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/baseEnvelope"},
    {
      "properties": {
        "event_type": {"const": "run.started"},
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenario_id", "runtime", "active_seat_ids"],
          "properties": {
            "scenario_id": {"type": "string"},
            "runtime": {"type": "string", "enum": ["wayflow", "langgraph"]},
            "active_seat_ids": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/roleId"}},
            "ticker": {"type": "string", "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"}
          }
        }
      }
    }
  ]
}
