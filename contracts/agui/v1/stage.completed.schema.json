{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/agui/v1/stage.completed.schema.json",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/baseEnvelope"},
    {
      "properties": {
        "event_type": {"const": "stage.completed"},
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {"type": "string", "enum": ["success", "warning", "failed"]}
          }
        }
      }
    }
  ]
}
