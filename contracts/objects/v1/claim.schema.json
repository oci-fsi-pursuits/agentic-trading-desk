{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/objects/v1/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "claim_id", "stance", "statement", "supporting_evidence_ids", "confidence", "provenance"],
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/$defs/schemaVersion"},
    "claim_id": {"$ref": "common.schema.json#/$defs/identifier"},
    "stance": {"type": "string", "enum": ["bull", "bear", "neutral", "dissent"]},
    "statement": {"type": "string", "minLength": 1},
    "supporting_evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "common.schema.json#/$defs/identifier"}
    },
    "counter_evidence_ids": {
      "type": "array",
      "items": {"$ref": "common.schema.json#/$defs/identifier"},
      "default": []
    },
    "confidence": {"$ref": "common.schema.json#/$defs/confidence"},
    "provenance": {"$ref": "common.schema.json#/$defs/provenance"}
  }
}
