{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/objects/v1/evidence.schema.json",
  "title": "Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_id", "evidence_type", "title", "summary", "source_ids", "confidence", "provenance", "tags"],
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/$defs/schemaVersion"},
    "evidence_id": {"$ref": "common.schema.json#/$defs/identifier"},
    "evidence_type": {"type": "string"},
    "title": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "common.schema.json#/$defs/identifier"}
    },
    "confidence": {"$ref": "common.schema.json#/$defs/confidence"},
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "common.schema.json#/$defs/tag"}
    },
    "provenance": {"$ref": "common.schema.json#/$defs/provenance"}
  }
}
