{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/objects/v1/trade-ticket.schema.json",
  "title": "Trade Ticket v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ticket_id",
    "ticket_type",
    "display_instrument",
    "legs",
    "exposure",
    "time_horizon",
    "entry_conditions",
    "exit_conditions",
    "constraint_ids",
    "approved_by",
    "provenance"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "v2"},
    "ticket_id": {"$ref": "common.schema.json#/$defs/identifier"},
    "ticket_type": {"type": "string", "enum": ["single_leg", "pair_trade"]},
    "display_instrument": {"type": "string", "minLength": 1},
    "legs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["leg_id", "instrument", "side", "size_bps", "role"],
        "properties": {
          "leg_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "instrument": {"type": "string", "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"},
          "side": {"type": "string", "enum": ["BUY", "SELL", "HOLD"]},
          "size_bps": {"type": "number", "minimum": 0},
          "role": {"type": "string", "enum": ["primary", "hedge"]}
        }
      }
    },
    "exposure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gross_bps", "net_bps"],
      "properties": {
        "gross_bps": {"type": "number", "minimum": 0},
        "net_bps": {"type": "number"}
      }
    },
    "time_horizon": {"type": "string", "enum": ["event_tactical", "swing", "core_position"]},
    "entry_conditions": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "exit_conditions": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "constraint_ids": {
      "type": "array",
      "items": {"$ref": "common.schema.json#/$defs/identifier"},
      "default": []
    },
    "approved_by": {"$ref": "common.schema.json#/$defs/roleId"},
    "provenance": {"$ref": "common.schema.json#/$defs/provenance"}
  }
}
