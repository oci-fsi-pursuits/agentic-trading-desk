        ],
        "optional_roles": [],
        "parallel": false,
        "required_inputs": [
          "decision",
          "constraint"
        ],
        "expected_outputs": [
          "decision"
        ],
        "timeout_s": 120,
        "on_seat_failure": "fail_stage",
        "ui_panels": [
