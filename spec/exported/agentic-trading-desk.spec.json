        {
          "type": "function",
          "name": "get_stock_data",
          "description": "Fetch recent ticker price bars for technical analysis.",
          "parameters": {
            "type": "object",
            "properties": {
              "ticker": {
                "type": "string"
              },
              "lookback_days": {
                "type": "integer",
                "minimum": 5,
                "maximum": 365
              }
            },
            "required": [
              "ticker"
            ],
            "additionalProperties": false
          }
        },
        {
          "type": "function",
          "name": "get_indicators",
          "description": "Compute technical indicators for the ticker.",
          "parameters": {
            "type": "object",
            "properties": {
              "ticker": {
                "type": "string"
              },
              "indicators": {
                "anyOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "lookback_days": {
                "type": "integer",
                "minimum": 30,
                "maximum": 365
              }
            },
            "required": [
              "ticker"
            ],
            "additionalProperties": false
          }
        }
