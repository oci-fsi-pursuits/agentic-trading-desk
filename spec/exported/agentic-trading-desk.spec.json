    {
      "component_type": "Flow",
      "id": "investment_committee_v1",
      "name": "Investment Committee Flow",
      "stages": [
        {
          "id": "gather",
          "name": "Gather",
          "purpose": "Collect raw inputs and initial evidence before the desk argues the thesis.",
          "agents": [
            "market_analyst",
            "news_analyst",
            "fundamentals_analyst"
          ],
          "optional_agents": [
            "social_analyst",
            "macro_economist",
            "geopolitical_analyst"
          ],
          "parallel": true,
          "required_inputs": [
            "scenario",
            "dataset_refs"
          ],
          "expected_outputs": [
            "source",
            "evidence"
          ],
          "timeout_s": 60,
          "on_seat_failure": "fallback_if_optional_fail_if_required",
          "ui_panels": [
            "phase_navigator",
            "research_summary",
            "transcript"
          ]
        },
        {
          "id": "quantify",
          "name": "Quantify",
          "purpose": "Execute quant validation early so debate can use quantitative signal and risk context.",
          "agents": [
            "quant_analyst"
          ],
          "optional_agents": [],
          "parallel": false,
          "required_inputs": [
            "evidence",
            "datasets"
          ],
          "expected_outputs": [
            "metric",
            "artifact"
          ],
          "timeout_s": 45,
          "on_seat_failure": "fail_stage",
          "ui_panels": [
            "quant_notebook",
            "research_summary"
          ]
        },
        {
          "id": "debate",
          "name": "Debate",
          "purpose": "Generate competing claims using gathered evidence and quant validation.",
          "agents": [
            "bull_researcher",
            "bear_researcher"
          ],
          "optional_agents": [
            "aggressive_analyst",
            "conservative_analyst",
            "neutral_analyst"
          ],
          "parallel": true,
          "required_inputs": [
            "evidence",
            "metric"
          ],
          "expected_outputs": [
            "claim"
          ],
          "timeout_s": 40,
          "on_seat_failure": "skip_optional_fail_if_bull_or_bear_absent",
          "ui_panels": [
            "debate_strip",
            "evidence_workspace"
          ]
        },
        {
          "id": "synthesize",
          "name": "Synthesize",
          "purpose": "Produce the combined research recommendation.",
          "agents": [
            "research_manager"
          ],
          "optional_agents": [],
          "parallel": false,
          "required_inputs": [
            "evidence",
            "claim",
            "metric"
          ],
          "expected_outputs": [
            "decision",
            "artifact"
          ],
          "timeout_s": 20,
          "on_seat_failure": "fail_stage",
          "ui_panels": [
            "recommendation_panel"
          ]
        },
        {
          "id": "risk_review",
          "name": "Risk Review",
          "purpose": "Apply mandate and portfolio constraints to the draft decision.",
          "agents": [
            "risk_manager"
          ],
          "optional_agents": [],
          "parallel": false,
          "required_inputs": [
            "decision",
            "constraint"
          ],
          "expected_outputs": [
            "constraint",
            "decision",
            "artifact"
          ],
          "timeout_s": 20,
          "on_seat_failure": "fail_stage",
          "ui_panels": [
            "risk_gate"
          ]
        },
        {
          "id": "pm_review",
          "name": "Pm Review",
          "purpose": "Capture PM approval, rejection, or edits.",
          "agents": [
            "portfolio_manager"
          ],
          "optional_agents": [],
          "parallel": false,
          "required_inputs": [
            "decision",
            "constraint"
          ],
          "expected_outputs": [
            "decision"
          ],
          "timeout_s": 120,
          "on_seat_failure": "fail_stage",
          "ui_panels": [
            "pm_action_panel"
          ]
        },
        {
          "id": "trade_finalize",
          "name": "Trade Finalize",
          "purpose": "Turn the approved decision and final constraints into a trade ticket.",
          "agents": [
            "trader"
          ],
          "optional_agents": [],
          "parallel": false,
          "required_inputs": [
            "decision",
            "constraint"
          ],
          "expected_outputs": [
            "trade_ticket",
            "artifact"
          ],
          "timeout_s": 15,
          "on_seat_failure": "fail_stage",
          "ui_panels": [
            "trader_handoff"
          ]
        },
        {
          "id": "monitor",
          "name": "Monitor",
          "purpose": "Track post-decision state and hand back the monitoring plan.",
          "agents": [
            "trader"
          ],
          "optional_agents": [
            "macro_economist",
            "geopolitical_analyst",
            "social_analyst"
          ],
          "parallel": true,
          "required_inputs": [
            "trade_ticket"
          ],
          "expected_outputs": [
            "artifact"
          ],
          "timeout_s": 30,
          "on_seat_failure": "continue_with_warnings",
          "ui_panels": [
            "monitor_panel",
            "transcript"
          ]
        }
      ]
    }
  ],
